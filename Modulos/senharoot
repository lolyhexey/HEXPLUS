#!/bin/bash

echo -e "\033[1;31mคำเตือน!!\033[0m"
echo " "
echo -e "\033[1;33mรหัสผ่านนี้จะใช้สำหรับเข้าสู่เซิร์ฟเวอร์ของคุณ
\033[0m"
echo -e "\033[1;32mกรอกรหัสผ่านใหม่ \033[1;32m
เพื่อดำเนินการต่อ...\033[1;31m\033[0m"
read  -p : pass
[[ -z "$pass" ]] && {
	echo -e "\033[1;31m[ผิดพลาด]\033[1;33m เปลี่ยนรหัสผ่าน root ไม่สำเร็จ: ไม่ได้กรอกรหัสผ่าน — กรุณารันใหม่แล้วกรอกรหัสผ่านที่ต้องการ\033[0m"
	sleep 3s
	exit 1
}
if (echo $pass; echo $pass)|passwd 2>/dev/null; then
sleep 1s
echo -e "\033[1;32mเปลี่ยนรหัสผ่านเรียบร้อยแล้ว!\033[0m"
else
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m เปลี่ยนรหัสผ่าน root ไม่สำเร็จ: คำสั่ง passwd ล้มเหลว — รหัสผ่านอาจสั้นหรือง่ายเกินไป ลองใช้รหัสผ่านที่ยาวขึ้น\033[0m"
fi
sleep 5s
cd
clear

