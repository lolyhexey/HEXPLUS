#!/bin/bash
#-----kiritosshxd------
fun_swap() {
    clear
		echo -e "\E[44;1;37m            จัดการหน่วยความจำเสมือน (SWAP)             \E[0m"
        echo ""
		echo -e "\033[1;31mSwap คือพื้นที่สำรองที่ใช้เพิ่มปริมาณหน่วยความจำ RAM \nของระบบ (แนะนำสำหรับเครื่องที่มี RAM น้อย)\033[0m"
        echo -e "\033[1;31mก่อนเปิดใช้งาน ควรตรวจสอบพื้นที่ดิสก์ของเครื่องก่อน \nและเหลือพื้นที่ว่างไว้เสมอเพื่อป้องกันเครื่องค้าง\033[0m"
        echo ""
		echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;37m• \033[1;33mเปิดใช้งาน SWAP / เปลี่ยนขนาด SWAP \033[0m"
		echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;37m• \033[1;33mปิดใช้งาน SWAP\033[0m"
		echo -e "\033[1;31m[\033[1;36m0\033[1;31m] \033[1;37m• \033[1;33mกลับ\033[0m"
		echo ""
		echo -ne "\033[1;32mต้องการทำอะไร \033[1;33m?\033[1;37m "
		read resposta
		if [[ "$resposta" = '1' ]]; then
            clear
			echo -e "\E[44;1;37m            หน่วยความจำเสมือน              \E[0m"
			echo ""
			echo -ne "\033[1;32mต้องการใช้พื้นที่กี่ GB \033[1;33m?\033[1;37m: "
			read gigas
            [[ ! "$gigas" =~ ^[0-9]+$ || "$gigas" -lt 1 ]] && {
					echo ""
					echo -e "\033[1;31m[ผิดพลาด]\033[1;33m สร้าง SWAP ไม่สำเร็จ: ขนาด swap ต้องเป็นตัวเลข (GB) — กรุณากรอกเป็นจำนวนเต็ม เช่น 1 หรือ 2\033[0m"
					sleep 2
					clear
					menu
				}
            echo ""
			echo -e "\033[1;32mกำลังเปิดใช้งานหน่วยความจำเสมือน \033[1;31m$gigas GB\033[1;33m"
			echo ""
            swapoff -a
            rm -rf /bin/ram.img > /dev/null 2>&1
            avail_kb=$(df -Pk /bin 2>/dev/null | awk 'NR==2 {print $4}')
            [[ "$avail_kb" =~ ^[0-9]+$ && $((gigas * 1048576)) -gt "$avail_kb" ]] && {
                echo ""
                echo -e "\033[1;31m[ผิดพลาด]\033[1;33m สร้าง SWAP ไม่สำเร็จ: พื้นที่ดิสก์ไม่พอ (ต้องการ ${gigas} GB แต่เหลือพื้นที่ว่างน้อยกว่านั้น) — โปรดลดขนาด swap หรือลบไฟล์ที่ไม่จำเป็นแล้วลองใหม่ (ดูพื้นที่ด้วย df -h)\033[0m"
                sleep 3
                fun_swap
                return
            }
            fallocate -l ${gigas}G /bin/ram.img > /dev/null 2>&1
            chmod 600 /bin/ram.img > /dev/null 2>&1
            mkswap /bin/ram.img > /dev/null 2>&1 || {
                echo ""
                echo -e "\033[1;31m[ผิดพลาด]\033[1;33m สร้าง SWAP ไม่สำเร็จ: คำสั่ง mkswap ล้มเหลว (อาจสร้างไฟล์ /bin/ram.img ได้ไม่ครบเพราะพื้นที่ดิสก์ไม่พอ) — ตรวจสอบพื้นที่ด้วย df -h แล้วลองใหม่ด้วยขนาดที่เล็กลง\033[0m"
                rm -rf /bin/ram.img > /dev/null 2>&1
                sleep 3
                fun_swap
                return
            }
            swapon /bin/ram.img > /dev/null 2>&1 || {
                echo ""
                echo -e "\033[1;31m[ผิดพลาด]\033[1;33m เปิดใช้งาน SWAP ไม่สำเร็จ: สร้างหรือเปิดไฟล์ swap ไม่ได้ — ตรวจสอบพื้นที่ดิสก์ว่าง (df -h) แล้วลองใหม่ด้วยขนาดที่เล็กลง\033[0m"
                sleep 3
                fun_swap
                return
            }
            echo 50  > /proc/sys/vm/swappiness
            echo '/bin/ram.img none swap sw 0 0' | sudo tee -a /etc/fstab > /dev/null 2>&1
            echo ""
			echo -e "\033[1;32mเปิดใช้งานหน่วยความจำเสมือนเรียบร้อยแล้ว\033[1;33m"
            sleep 2
			fun_swap
        elif [[ "$resposta" = '2' ]]; then
            clear
			echo -e "\E[44;1;37m            กำลังปิดใช้งานหน่วยความจำเสมือน              \E[0m"
            swapoff -a
            rm -rf /bin/ram.img > /dev/null 2>&1
            echo ""
			echo -e "\033[1;32mปิดใช้งานหน่วยความจำเสมือนเรียบร้อยแล้ว!\033[1;33m"
			sleep 2
			fun_swap
        elif [[ "$resposta" = '0' ]]; then
			echo ""
			echo -e "\033[1;31mกำลังกลับ...\033[0m"
			sleep 1
			menu
		else
			echo ""
			echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ตัวเลือกไม่ถูกต้อง: '$resposta' ไม่อยู่ในเมนู — กรุณาเลือก 0-2\033[0m"
			sleep 1
			fun_swap
		fi 
}
fun_swap