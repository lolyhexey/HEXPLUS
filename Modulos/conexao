	fun_openssh() {
		clear
		echo -e "\E[44;1;37m            OPENSSH             \E[0m\n"
		echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;37m• \033[1;33mเพิ่มพอร์ตSSH\033[1;31m
[\033[1;36m2\033[1;31m] \033[1;37m• \033[1;33mลบพอร์ตSSH\033[1;31m
[\033[1;36m3\033[1;31m] \033[1;37m• \033[1;33mย้อนกลับ\033[0m"
		echo ""
		echo -ne "\033[1;32mเลือกตัวเลือก \033[1;33m?\033[1;37m "
		read resp
		if [[ "$resp" = '1' ]]; then
			clear
			echo -e "\E[44;1;37m         เพิ่มพอร์ตให้ SSH         \E[0m\n"
			echo -ne "\033[1;32mใส่พอร์ตที่คุณต้องการ \033[1;33m?\033[1;37m "
			read pt
			[[ -z "$pt" ]] && {
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m พอร์ตไม่ถูกต้อง: ไม่ได้ระบุพอร์ต — พอร์ตต้องเป็นตัวเลข 1-65535\033[0m"
				sleep 3
				fun_conexao
			}
			verif_ptrs $pt
			echo -e "\n\033[1;32mกำลังเพิ่มพอร์ตให้ SSH\033[0m"
			echo ""
			fun_addpssh() {
				echo "Port $pt" >>/etc/ssh/sshd_config
				service ssh restart
			}
			fun_bar 'fun_addpssh'
			netstat -nlt 2>/dev/null | grep -w "$pt" >/dev/null && echo -e "\n\033[1;32mเพิ่มพอร์ต SSH สำเร็จเรียบร้อยแล้ว\033[0m" || echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m SSH เริ่มทำงานบนพอร์ต $pt ไม่สำเร็จ: บริการ ssh อาจรีสตาร์ทไม่สำเร็จ — ตรวจสอบด้วย sshd -t และ service ssh status\033[0m"
			sleep 3
			fun_conexao
		elif [[ "$resp" = '2' ]]; then
			clear
			echo -e "\E[41;1;37m         ลบพอร์ตของ SSH         \E[0m"
			echo -e "\n\033[1;33m[\033[1;31m!\033[1;33m] \033[1;32mพอร์ตเริ่มต้น \033[1;37m22 \033[1;33mโปรดระวัง !\033[0m"
			echo -e "\n\033[1;33mพอร์ตที่ใช้งานอยู่: \033[1;37m$(grep 'Port' /etc/ssh/sshd_config | cut -d' ' -f2 | grep -v 'no' | xargs)\n"
			echo -ne "\033[1;32mต้องการลบพอร์ตใด \033[1;33m?\033[1;37m "
			read pt
			[[ -z "$pt" ]] && {
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m พอร์ตไม่ถูกต้อง: ไม่ได้ระบุพอร์ต — พอร์ตต้องเป็นตัวเลข 1-65535\033[0m"
				sleep 2
				fun_conexao
			}
			[[ $(grep -wc "$pt" '/etc/ssh/sshd_config') != '0' ]] && {
				echo -e "\n\033[1;32mกำลังลบพอร์ตของ SSH\033[0m"
				echo ""
				fun_delpssh() {
					sed -i "/Port $pt/d" /etc/ssh/sshd_config
					service ssh restart
				}
				fun_bar 'fun_delpssh'
				echo -e "\n\033[1;32mลบพอร์ตสำเร็จแล้ว\033[0m"
				sleep 2
				fun_conexao
			} || {
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m ลบพอร์ตไม่สำเร็จ: ไม่พบพอร์ต $pt ใน sshd_config — ตรวจสอบรายการพอร์ตที่แสดงด้านบน\033[0m"
				sleep 2
				fun_conexao
			}
		elif [[ "$resp" = '3' ]]; then
			echo -e "\n\033[1;31mย้อนกลับ.."
			sleep 2
			fun_conexao
		else
			echo -e "\n\033[1;31mกรุณาเลือกให้ถูกต้อง!"
			sleep 2
			fun_conexao
		fi
	}

	fun_sslh() {
		[[ "$(netstat -nltp | grep 'sslh' | wc -l)" = '0' ]] && {
			clear
			echo -e "\E[44;1;37m             ติดตั้ง SSLH               \E[0m\n"
			echo -e "\n\033[1;33m[\033[1;31m!\033[1;33m] \033[1;32mพอร์ต \033[1;37m443 \033[1;32mจะถูกใช้เป็นค่าเริ่มต้น\033[0m\n"
			echo -ne "\033[1;32mคุณต้องการติดตั้ง SSLH จริงหรือไม่ \033[1;31m? \033[1;33m[s/n]:\033[1;37m "
			read resp
			[[ "$resp" = 's' ]] && {
				verif_ptrs 443
				fun_instsslh() {
					[[ -e "/etc/stunnel/stunnel.conf" ]] && ptssl="$(netstat -nplt | grep 'stunnel' | awk {'print $4'} | cut -d: -f2 | xargs)" || ptssl='3128'
					[[ -e "/etc/openvpn/server.conf" ]] && ptvpn="$(netstat -nplt | grep 'openvpn' | awk {'print $4'} | cut -d: -f2 | xargs)" || ptvpn='1194'
					DEBIAN_FRONTEND=noninteractive apt-get -y install sslh
					echo -e "#Modo autónomo\n\nRUN=yes\n\nDAEMON=/usr/sbin/sslh\n\nDAEMON_OPTS='--user sslh --listen 0.0.0.0:443 --ssh 127.0.0.1:22 --ssl 127.0.0.1:$ptssl --http 127.0.0.1:80 --openvpn 127.0.0.1:$ptvpn --pidfile /var/run/sslh/sslh.pid'" >/etc/default/sslh
					/etc/init.d/sslh start && service sslh start
				}
				echo -e "\n\033[1;32mกำลังติดตั้ง SSLH !\033[0m\n"
				fun_bar 'fun_instsslh'
				echo -e "\n\033[1;32mกำลังเริ่ม SSLH !\033[0m\n"
				fun_bar '/etc/init.d/sslh restart && service sslh restart'
				[[ $(netstat -nplt | grep -w 'sslh' | wc -l) != '0' ]] && echo -e "\n\033[1;32mติดตั้งสำเร็จแล้ว !\033[0m" || echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m SSLH เริ่มทำงานไม่สำเร็จ: พอร์ต 443 อาจถูกใช้งานอยู่ — ตรวจสอบด้วย service sslh status\033[0m"
				sleep 3
				fun_conexao
			} || {
				echo -e "\n\033[1;31mย้อนกลับ.."
				sleep 2
				fun_conexao
			}
		} || {
			clear
			echo -e "\E[41;1;37m             ลบ SSLH               \E[0m\n"
			echo -ne "\033[1;32mคุณต้องการลบ SSLH จริงหรือไม่ \033[1;31m? \033[1;33m[s/n]:\033[1;37m "
			read respo
			[[ "$respo" = "s" ]] && {
				fun_delsslh() {
					/etc/init.d/sslh stop && service sslh stop
					apt-get remove sslh -y
					apt-get purge sslh -y
				}
				echo -e "\n\033[1;32mกำลังลบ SSLH !\033[0m\n"
				fun_bar 'fun_delsslh'
				echo -e "\n\033[1;32mลบสำเร็จแล้ว !\033[0m\n"
				sleep 2
				fun_conexao
			} || {
				echo -e "\n\033[1;31mย้อนกลับ.."
				sleep 2
				fun_conexao
			}
		}
	}

