#!/bin/bash
#====================================================
#	@lolyhexey
#====================================================
cor1='\033[41;1;37m'
cor2='\033[44;1;37m'
scor='\033[0m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
SCOLOR='\033[0m'
[[ $(awk -F" " '{print $2}' /usr/lib/licence) == "@lolyhexey" ]] && {
	ram1=$(free -h | grep -i mem | awk {'print $2'})
	ram2=$(free -h | grep -i mem | awk {'print $4'})
	ram3=$(free -h | grep -i mem | awk {'print $3'})
	uso=$(top -bn1 | awk '/Cpu/ { cpu = "" 100 - $8 "%" }; END { print cpu }')
	system=$(cat /etc/issue.net)
	HEXPLUS_LOG="${HEXPLUS_LOG:-/var/log/hexplus-install.log}"
	fun_bar() {
		comando[0]="$1"
		comando[1]="$2"
		mkdir -p "$(dirname "$HEXPLUS_LOG")" 2>/dev/null
		{
			echo ""
			echo "===== $(date '+%Y-%m-%d %H:%M:%S') | ${comando[0]} ====="
		} >>"$HEXPLUS_LOG" 2>&1
		(
			export DEBIAN_FRONTEND=noninteractive
			export NEEDRESTART_MODE=a
			export NEEDRESTART_SUSPEND=1
			[[ -e $HOME/fim ]] && rm $HOME/fim
			[[ ! -d /etc/SSHPlus ]] && rm -rf /bin/menu
			${comando[0]} </dev/null >>"$HEXPLUS_LOG" 2>&1
			${comando[1]} </dev/null >>"$HEXPLUS_LOG" 2>&1
			touch $HOME/fim
		) </dev/null >>"$HEXPLUS_LOG" 2>&1 &
		tput civis
		echo -ne "\033[1;33mกรุณารอสักครู่ \033[1;37m- \033[1;33m["
		while true; do
			for ((i = 0; i < 18; i++)); do
				echo -ne "\033[1;31m#"
				sleep 0.1s
			done
			[[ -e $HOME/fim ]] && rm $HOME/fim && break
			echo -e "\033[1;33m]"
			sleep 1s
			tput cuu1
			tput dl1
			echo -ne "\033[1;33mกรุณารอสักครู่ \033[1;37m- \033[1;33m["
		done
		echo -e "\033[1;33m]\033[1;37m -\033[1;32m OK !\033[1;37m"
		tput cnorm
	}

	verif_ptrs() {
		porta=$1
		[[ ! "$porta" =~ ^[0-9]+$ || "$porta" -lt 1 || "$porta" -gt 65535 ]] && {
			echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m พอร์ตไม่ถูกต้อง: '$porta' — พอร์ตต้องเป็นตัวเลข 1-65535\033[0m"
			sleep 3
			fun_conexao
		}
		PT=$(lsof -V -i tcp -P -n | grep -v "ESTABLISHED" | grep -v "COMMAND" | grep "LISTEN")
		for pton in $(echo -e "$PT" | cut -d: -f2 | cut -d' ' -f1 | uniq); do
			svcs=$(echo -e "$PT" | grep -w "$pton" | awk '{print $1}' | uniq)
			[[ "$porta" = "$pton" ]] && {
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m พอร์ต $porta: พอร์ตนี้ถูกใช้งานอยู่แล้วโดย $svcs — โปรดเลือกพอร์ตอื่น\033[0m"
				sleep 3
				fun_conexao
			}
		done
	}

	inst_sqd() {
		if netstat -nltp | grep 'squid' 1>/dev/null 2>/dev/null; then
			echo -e "\E[41;1;37m            ถอนการติดตั้งพร็อกซี่              \E[0m"
			echo ""
			echo -ne "\033[1;32mคุณต้องการลบ SQUID จริงหรือไม่ \033[1;31m? \033[1;33m[s/n]:\033[1;37m "
			read resp
			[[ "$resp" = 's' ]] && {
				echo -e "\n\033[1;32mกำลังลบ SQUID PROXY !\033[0m"
				echo ""
				rem_sqd() {
					[[ -d "/etc/squid" ]] && {
						apt-get remove squid -y >/dev/null 2>&1
						apt-get purge squid -y >/dev/null 2>&1
						rm -rf /etc/squid >/dev/null 2>&1
					}
					[[ -d "/etc/squid3" ]] && {
						apt-get remove squid3 -y >/dev/null 2>&1
						apt-get purge squid3 -y >/dev/null 2>&1
						rm -rf /etc/squid3 >/dev/null 2>&1
						apt autoremove -y >/dev/null 2>&1
					}
				}
				fun_bar 'rem_sqd'
				echo -e "\n\033[1;32mลบ SQUID สำเร็จแล้ว !\033[0m"
				sleep 2
				clear
				fun_conexao
			} || {
				echo -e "\n\033[1;31mย้อนกลับ...\033[0m"
				sleep 2
				clear
				fun_conexao
			}
		else
			clear
			echo -e "\E[44;1;37m              ติดตั้งพร็อกซี่                \E[0m"
			echo ""
			IP=$(wget -qO- ipv4.icanhazip.com)
			echo -ne "\033[1;32mยืนยัน IP ของคุณเพื่อดำเนินการต่อ: \033[1;37m"
			read -e -i $IP ipdovps
			[[ -z "$ipdovps" ]] && {
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m IP ไม่ถูกต้อง: ค่าว่างเปล่า — กรุณาใส่ IP ของเซิร์ฟเวอร์\033[1;32m"
				echo ""
				read -p "กรุณาใส่ IP ของคุณ: " IP
			}
			echo -e "\n\033[1;33mกรุณาใส่พอร์ตที่คุณต้องการ \033[1;31m?"
			echo -e "\n\033[1;33m[\033[1;31m!\033[1;33m] \033[1;32mพอร์ตพร็อกซี่ตัวอย่าง \033[1;33mEX: \033[1;37m80 8080"
			echo ""
			echo -ne "\033[1;32mกรุณาใส่พอร์ต\033[1;37m: "
			read portass
			[[ -z "$portass" ]] && {
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m พอร์ตไม่ถูกต้อง: ไม่ได้ระบุพอร์ต — พอร์ตต้องเป็นตัวเลข 1-65535\033[0m"
				sleep 3
				fun_conexao
			}
			for porta in $(echo -e $portass); do
				verif_ptrs $porta
			done
			[[ $(grep -wc '14' /etc/issue.net) != '0' ]] || [[ $(grep -wc '8' /etc/issue.net) != '0' ]] && {
				echo -e "\n\033[1;32mกำลังติดตั้งพร็อกซี่\033[0m\n"
				fun_bar 'apt update -y' "apt install squid3 -y"
			} || {
				echo -e "\n\033[1;31m[\033[1;36m1\033[1;31m] \033[1;37m• \033[1;33mพร็อกซี่เวอร์ชั่น 3.3.X\n\033[1;31m[\033[1;36m2\033[1;31m] \033[1;37m• \033[1;33mพร็อกซี่เวอร์ชั่น 3.5.X\033[0m\n"
				read -p "$(echo -e "\033[1;32mเลือกเวอร์ชั่น? \033[1;37m: ")" -e -i 1 opc
				[[ -z "$opc" ]] && {
					echo -e "\n\033[1;31mกรุณาเลือกให้ถูกต้อง!"
					sleep 2
					fun_conexao
				}
				[[ "$opc" != '1' ]] && {
					[[ "$opc" != '2' ]] && {
						echo -e "\n\033[1;31mกรุณาเลือกให้ถูกต้อง !"
						sleep 2
						fun_conexao
					}
				}
				echo -e "\n\033[1;32mกำลังติดตั้งพร็อกซี่\033[0m\n"
				fun_bar 'apt update -y' "instsqd $opc"
			}
			if [[ -d "/etc/squid/" ]]; then
				var_sqd="/etc/squid/squid.conf"
				var_pay="/etc/squid/payload.txt"
			elif [[ -d "/etc/squid3/" ]]; then
				var_sqd="/etc/squid3/squid.conf"
				var_pay="/etc/squid3/payload.txt"
			else
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m SQUID PROXY: ไม่พบโฟลเดอร์การตั้งค่า /etc/squid — การติดตั้งล้มเหลว กรุณาลองติดตั้งใหม่\033[0m"
				sleep 2
				fun_conexao
			fi
			cat <<-EOF >$var_pay
				.whatsapp.net/
				.facebook.net/
				.twitter.com/
				.speedtest.net/
			EOF
			cat <<-EOF >$var_sqd
http_port $porta
acl localhost src 127.0.0.1/32 ::1
acl to_localhost dst 127.0.0.0/8 0.0.0.0/32 ::1
acl localnet src 10.0.0.0/8
acl localnet src 172.16.0.0/12
acl localnet src 192.168.0.0/16
acl SSL_ports port 443
acl Safe_ports port 80
acl Safe_ports port 21
acl Safe_ports port 443
acl Safe_ports port 70
acl Safe_ports port 210
acl Safe_ports port 1025-65535
acl Safe_ports port 280
acl Safe_ports port 488
acl Safe_ports port 591
acl Safe_ports port 777
acl CONNECT method CONNECT
acl SSH dst $IP-$IP/255.255.255.255 
acl SSH dst 127.0.0.1-127.0.0.1/255.255.255.255                 
http_access allow SSH
http_access allow localnet
http_access allow localhost
http_access deny all
refresh_pattern ^ftp:           1440    20%     10080
refresh_pattern ^gopher:        1440    0%      1440
refresh_pattern -i (/cgi-bin/|\?) 0     0%      0
refresh_pattern .               0       20%     4320
				 
				#Portas
			EOF
			for Pts in $(echo -e $portass); do
				echo -e "http_port $Pts" >>$var_sqd
				[[ -f "/usr/sbin/ufw" ]] && ufw allow $Pts/tcp
			done
			cat <<-EOF >>$var_sqd
				#Nome squid
				visible_hostname HEXPLUS
				via off
				forwarded_for off
				pipeline_prefetch off
			EOF
			sqd_conf() {
				[[ -d "/etc/squid/" ]] && {
					service ssh restart
					/etc/init.d/squid restart
					service squid restart
				}
				[[ -d "/etc/squid3/" ]] && {
					service ssh restart
					/etc/init.d/squid3 restart
					service squid3 restart
				}
			}
			echo -e "\n\033[1;32mกำลังตั้งค่า SQUID PROXY\033[0m"
			echo ""
			fun_bar 'sqd_conf'
			netstat -nltp 2>/dev/null | grep 'squid' >/dev/null && echo -e "\n\033[1;32mติดตั้งพร็อกซี่สำเร็จแล้ว!\033[0m" || echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m SQUID เริ่มทำงานไม่สำเร็จ: บริการไม่ทำงานหลังติดตั้ง\n  ดู log ละเอียดได้ที่: \033[1;36m$HEXPLUS_LOG\033[1;33m\n  ดูเฉพาะ error: \033[1;36mgrep -iE 'err|fail|fatal|cannot|unable|not found' $HEXPLUS_LOG | tail -20\033[1;33m\n  หรือเช็คสถานะ: \033[1;36mservice squid status\033[0m"
			sleep 2.5s
			fun_conexao
		fi
	}

	addpt_sqd() {
		echo -e "\E[44;1;37m         เพิ่มพอร์ตพร็อกซี่         \E[0m"
		echo -e "\n\033[1;33mพอร์ตที่ใช้งานอยู่: \033[1;32m$sqdp\n"
		if [[ -f "/etc/squid/squid.conf" ]]; then
			var_sqd="/etc/squid/squid.conf"
		elif [[ -f "/etc/squid3/squid.conf" ]]; then
			var_sqd="/etc/squid3/squid.conf"
		else
			echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m SQUID ยังไม่ได้ติดตั้ง: ไม่พบไฟล์ squid.conf — กรุณาติดตั้ง SQUID ก่อน\033[0m"
			echo -e "\n\033[1;31mย้อนกลับ...\033[0m"
			sleep 2
			clear
			fun_squid
		fi
		echo -ne "\033[1;32mใส่พอร์ตที่คุณต้องการ \033[1;33m?\033[1;37m "
		read pt
		[[ -z "$pt" ]] && {
			echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m พอร์ตไม่ถูกต้อง: ไม่ได้ระบุพอร์ต — พอร์ตต้องเป็นตัวเลข 1-65535\033[0m"
			sleep 2
			clear
			fun_conexao
		}
		verif_ptrs $pt
		echo -e "\n\033[1;32mกำลังเพิ่มพอร์ตให้ SQUID!"
		echo ""
		sed -i "s/#Portas/#Portas\nhttp_port $pt/g" $var_sqd
		fun_bar 'sleep 2'
		echo -e "\n\033[1;32mกำลังรีสตาร์ท SQUID!"
		echo ""
		fun_bar 'service squid restart' 'service squid3 restart'
		echo -e "\n\033[1;32mติดตั้งเสร็จเรียบร้อยเเล้ว!"
		sleep 3
		clear
		fun_squid
	}

	rempt_sqd() {
		echo -e "\E[41;1;37m        ลบพอร์ตของ SQUID        \E[0m"
		echo -e "\n\033[1;33mพอร์ตที่ใช้งานอยู่: \033[1;32m$sqdp\n"
		if [[ -f "/etc/squid/squid.conf" ]]; then
			var_sqd="/etc/squid/squid.conf"
		elif [[ -f "/etc/squid3/squid.conf" ]]; then
			var_sqd="/etc/squid3/squid.conf"
		else
			echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m SQUID ยังไม่ได้ติดตั้ง: ไม่พบไฟล์ squid.conf — กรุณาติดตั้ง SQUID ก่อน\033[0m"
			echo -e "\n\033[1;31mย้อนกลับ...\033[0m"
			sleep 2
			clear
			fun_squid
		fi
		echo -ne "\033[1;32mต้องการลบพอร์ตใด \033[1;33m?\033[1;37m "
		read pt
		[[ -z "$pt" ]] && {
			echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m พอร์ตไม่ถูกต้อง: ไม่ได้ระบุพอร์ต — พอร์ตต้องเป็นตัวเลข 1-65535\033[0m"
			sleep 2
			clear
			fun_conexao
		}
		if grep -E "$pt" $var_sqd >/dev/null 2>&1; then
			echo -e "\n\033[1;32mกำลังลบพอร์ตออกจาก SQUID!"
			echo ""
			sed -i "/http_port $pt/d" $var_sqd
			fun_bar 'sleep 3'
			echo -e "\n\033[1;32mกำลังรีสตาร์ท SQUID!"
			echo ""
			fun_bar 'service squid restart' 'service squid3 restart'
			echo -e "\n\033[1;32mลบพอร์ตสำเร็จแล้ว!"
			sleep 3.5s
			clear
			fun_squid
		else
			echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m ลบพอร์ตไม่สำเร็จ: ไม่พบพอร์ต $pt ในการตั้งค่า SQUID — ตรวจสอบรายการพอร์ตอีกครั้ง\033[0m"
			sleep 3.5s
			clear
			fun_squid
		fi
	}

	fun_squid() {
		[[ "$(netstat -nplt | grep -c 'squid')" = "0" ]] && inst_sqd
		echo -e "\E[44;1;37m          จัดการ SQUID PROXY           \E[0m"
		[[ "$(netstat -nplt | grep -c 'squid')" != "0" ]] && {
			sqdp=$(netstat -nplt | grep 'squid' | awk -F ":" {'print $4'} | xargs)
			echo -e "\n\033[1;33mพอร์ต\033[1;37m: \033[1;32m$sqdp"
			VarSqdOn="ถอนการติดตั้งพร็อกซี่"
		} || {
			VarSqdOn="ติดตั้ง SQUID PROXY"
		}
		echo -e "\n\033[1;31m[\033[1;36m1\033[1;31m] \033[1;37m• \033[1;33m$VarSqdOn \033[1;31m
[\033[1;36m2\033[1;31m] \033[1;37m• \033[1;33mเพิ่มพอร์ตพร็อกซี่ \033[1;31m
[\033[1;36m3\033[1;31m] \033[1;37m• \033[1;33mลบพอร์ตพร็อกซี่\033[1;31m
[\033[1;36m0\033[1;31m] \033[1;37m• \033[1;33mย้อนกลับ\033[0m"
		echo ""
		echo -ne "\033[1;32mเลือกตัวเลือก \033[1;33m?\033[1;31m?\033[1;37m "
		read x
		clear
		case $x in
		1 | 01)
			inst_sqd
			;;
		2 | 02)
			addpt_sqd
			;;
		3 | 03)
			rempt_sqd
			;;
		0 | 00)
			echo -e "\033[1;31mย้อนกลับ...\033[0m"
			sleep 1
			fun_conexao
			;;
		*)
			echo -e "\033[1;31mกรุณาเลือกให้ถูกต้อง...\033[0m"
			sleep 2
			fun_conexao
			;;
		esac
	}

	fun_drop() {
		if netstat -nltp | grep 'dropbear' 1>/dev/null 2>/dev/null; then
			clear
			[[ $(netstat -nltp | grep -c 'dropbear') != '0' ]] && dpbr=$(netstat -nplt | grep 'dropbear' | awk -F ":" {'print $4'} | xargs) || sqdp="\033[1;31mไม่พร้อมใช้งาน"
			if ps x | grep "limiter" | grep -v grep 1>/dev/null 2>/dev/null; then
				stats='\033[1;32m◉ '
			else
				stats='\033[1;31m○ '
			fi
			echo -e "\E[44;1;37m              จัดการ DROPBEAR               \E[0m"
			echo -e "\n\033[1;33mพอร์ต\033[1;37m: \033[1;32m$dpbr"
			echo ""
			echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;37m• \033[1;33mLIMITER DROPBEAR $stats\033[0m"
			echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;37m• \033[1;33mเปลี่ยนพอร์ต DROPBEAR\033[0m"
			echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;37m• \033[1;33mลบ DROPBEAR\033[0m"
			echo -e "\033[1;31m[\033[1;36m0\033[1;31m] \033[1;37m• \033[1;33mย้อนกลับ\033[0m"
			echo ""
			echo -ne "\033[1;32mเลือกตัวเลือก \033[1;33m?\033[1;37m "
			read resposta
			if [[ "$resposta" = '1' ]]; then
				clear
				if ps x | grep "limiter" | grep -v grep 1>/dev/null 2>/dev/null; then
					echo -e "\033[1;32mกำลังหยุด limiter... \033[0m"
					echo ""
					fun_stplimiter() {
						pidlimiter=$(ps x | grep "limiter" | awk -F "pts" {'print $1'})
						kill -9 $pidlimiter
						screen -wipe
					}
					fun_bar 'fun_stplimiter' 'sleep 2'
					echo -e "\n\033[1;31m LIMITER ถูกปิดแล้ว \033[0m"
					sleep 3
					fun_drop
				else
					echo -e "\n\033[1;32mกำลังเริ่ม limiter... \033[0m"
					echo ""
					fun_bar 'screen -d -m -t limiter droplimiter' 'sleep 3'
					echo -e "\n\033[1;32m  LIMITER เปิดใช้งานแล้ว \033[0m"
					sleep 3
					fun_drop
				fi
			elif [[ "$resposta" = '2' ]]; then
				echo ""
				echo -ne "\033[1;32mต้องการใช้พอร์ตใด \033[1;33m?\033[1;37m "
				read pt
				echo ""
				verif_ptrs $pt
				var1=$(grep 'DROPBEAR_PORT=' /etc/default/dropbear | cut -d'=' -f2)
				echo -e "\033[1;32mกำลังเปลี่ยนพอร์ต DROPBEAR!"
				sed -i "s/\b$var1\b/$pt/g" /etc/default/dropbear >/dev/null 2>&1
				echo ""
				fun_bar 'sleep 2'
				echo -e "\n\033[1;32mกำลังรีสตาร์ท DROPBEAR!"
				echo ""
				fun_bar 'service dropbear restart' '/etc/init.d/dropbear restart'
