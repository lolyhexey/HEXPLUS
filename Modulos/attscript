#!/bin/bash

clear

HEXPLUS_REPO_RAW="https://raw.githubusercontent.com/lolyhexey/HEXPLUS/main"

fun_bar () {
comando[0]="$1"
comando[1]="$2"
(
[[ -e $HOME/fim ]] && rm $HOME/fim
${comando[0]} > /dev/null 2>&1
${comando[1]} > /dev/null 2>&1
touch $HOME/fim
) > /dev/null 2>&1 &
tput civis
echo -ne "   \033[1;33mกรุณารอสักครู่ \033[1;37m- \033[1;33m["
while true; do
for((i=0; i<18; i++)); do
echo -ne "\033[1;31m#"
sleep 0.1s
done
[[ -e $HOME/fim ]] && rm $HOME/fim && break
echo -e "\033[1;33m]"
sleep 1s
tput cuu1
tput dl1
echo -ne "   \033[1;33mกรุณารอสักครู่ \033[1;37m- \033[1;33m["
done
echo -e "\033[1;33m]\033[1;37m -\033[1;32m OK !\033[1;37m"
tput cnorm
}

fun_atts () {
rm -f /tmp/hexplus-versao /tmp/att >/dev/null 2>&1
wget -q -O /tmp/hexplus-versao "$HEXPLUS_REPO_RAW/Install/versao"
# ยืนยันว่าโหลดได้จริง (เจอ VERSAO: NN ที่บรรทัดแรก) ไม่ใช่ HTML 404
if [[ -s /tmp/hexplus-versao ]] && head -1 /tmp/hexplus-versao | grep -qE '^VERSAO: *[0-9]+'; then
mv /tmp/hexplus-versao /tmp/att
else
rm -f /tmp/hexplus-versao
fi
} > /dev/null 2>&1

echo " "
echo -e "                              \033[1;31mBy HEXPLUS\033[1;36m"
if command -v figlet >/dev/null 2>&1; then
echo "   HEXPlus" | figlet
else
echo -e "   \033[1;36mHEXPlus\033[0m"
fi
echo " "
echo -e "   \033[1;32mกำลังตรวจสอบอัปเดตที่มี\033[0m\n"
fun_bar 'fun_atts'

[[ ! -f "/tmp/att" ]] && {
echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m ตรวจสอบอัปเดตไม่สำเร็จ: ดาวน์โหลดไฟล์เวอร์ชันไม่ได้ หรือไฟล์ไม่ใช่ฟอร์แมตที่ถูกต้อง — เช็คอินเทอร์เน็ตของเซิร์ฟเวอร์\033[0m\n"
echo -ne "\033[1;33m กด \033[1;31mENTER \033[1;33mเพื่อกลับ\033[1;32mเมนู!\033[0m"; read
menu
exit 0
}

echo " "
vrs1=$(sed -n '1 p' /bin/versao 2>/dev/null | sed -e 's/[^0-9]//g')
vrs2=$(sed -n '1 p' /tmp/att | sed -e 's/[^0-9]//g')
[[ -z "$vrs1" ]] && vrs1=0
[[ -z "$vrs2" ]] && vrs2=0

[[ "$vrs1" == "$vrs2" ]] && {
echo -e " \033[1;36m     สคริปต์เป็นเวอร์ชันล่าสุดอยู่แล้ว!\033[1;32m (v$vrs1)\n"
rm /tmp/att > /dev/null 2>&1
echo -e " \033[1;33m ข้อมูลเพิ่มเติม \033[1;31m(\033[1;36mTELEGRAM\033[1;31m): \033[1;37mEDIT:@lolyhexey\n"
echo -ne " \033[1;33m กด \033[1;31mENTER \033[1;33mเพื่อกลับ\033[1;32mเมนู!\033[0m"; read
menu
exit 0
}

echo -e "  \033[1;36mมีอัปเดตเวอร์ชันใหม่พร้อมให้ติดตั้ง! \033[1;33m(v$vrs1 → v$vrs2)\n"
echo -e "  \033[1;33mข้อมูลเพิ่มเติม \033[1;31m(\033[1;36mTELEGRAM\033[1;31m): \033[1;37mEDIT:@lolyhexey\n"
echo -e "  \033[1;32mรายละเอียดการอัปเดต:\033[0m\n"

# โชว์เฉพาะ release notes — ข้ามบรรทัด VERSAO header, ชื่อ author, footer RECUSE, และบรรทัดว่าง
while IFS= read -r linha; do
[[ -z "$linha" ]] && continue
[[ "$linha" =~ ^VERSAO: ]] && continue
[[ "$linha" =~ ^@ ]] && continue
[[ "$linha" =~ ^--\[ ]] && continue
echo -e "  \033[1;37m- \033[1;33m$linha"
done < "/tmp/att"

echo " "
echo -ne "  \033[1;32mต้องการอัปเดตหรือไม่ \033[1;31m? \033[1;33m[s/n]:\033[1;37m "; read res

if [[ "$res" = s || "$res" = S ]]; then
echo -e "\n\033[1;32m  กำลังเริ่มอัปเดต..."
sleep 2
# โหลด Plus ไปที่ /root เสมอ ไม่พึ่ง CWD
rm -f /root/Plus >/dev/null 2>&1
if ! wget -q -O /root/Plus "$HEXPLUS_REPO_RAW/Plus"; then
echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m อัปเดตไม่สำเร็จ: ดาวน์โหลด Plus ไม่ได้ — เช็คอินเทอร์เน็ตของเซิร์ฟเวอร์\033[0m\n"
echo -ne "\033[1;33mกด \033[1;31mENTER \033[1;33mเพื่อกลับ\033[1;32mเมนู!\033[0m"; read
menu
exit 1
fi
# ยืนยันว่าโหลด Plus มาถูกจริง (บรรทัดแรกต้องเป็น shebang)
if ! head -1 /root/Plus | grep -q '^#!/bin/bash'; then
echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m อัปเดตไม่สำเร็จ: ไฟล์ Plus ที่โหลดมาไม่ใช่ bash script (อาจได้หน้า 404 จาก GitHub) — ลองใหม่อีกครั้ง\033[0m\n"
rm -f /root/Plus
echo -ne "\033[1;33mกด \033[1;31mENTER \033[1;33mเพื่อกลับ\033[1;32mเมนู!\033[0m"; read
menu
exit 1
fi
chmod +x /root/Plus
cd /root
bash /root/Plus
clear
echo -e "\033[1;32mอัปเดตสคริปต์เรียบร้อยแล้ว\033[0m\n"
rm /tmp/att > /dev/null 2>&1
echo -ne "\033[1;33mกด \033[1;31mENTER \033[1;33mเพื่อกลับ\033[1;32mเมนู!\033[0m"; read
menu
exit 0
else
rm /tmp/att > /dev/null 2>&1
menu
exit 0
fi
