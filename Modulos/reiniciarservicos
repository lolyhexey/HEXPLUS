#!/bin/bash
clear
fun_prog ()
{
	comando[0]="$1" 
    ${comando[0]}  > /dev/null 2>&1 & 
	tput civis
	echo -ne "\033[1;32m.\033[1;33m.\033[1;31m. \033[1;32m"
    while [ -d /proc/$! ]
	do
		for i in / - \\ \|
		do
			sleep .1
			echo -ne "\e[1D$i"
		done
	done
	tput cnorm
	echo -e "\e[1DOK"
}
echo -ne "\033[1;33mกำลังรีสตาร์ท OPENSSH "; fun_prog 'service ssh restart'
echo ""
sleep 1
if [[ -e /etc/squid/squid.conf ]]; then
echo -ne "\033[1;33mกำลังรีสตาร์ท SQUID PROXY "; fun_prog 'service squid restart'
echo ""
sleep 1
if ! pgrep -x squid > /dev/null 2>&1; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m รีสตาร์ท SQUID PROXY ไม่สำเร็จ: บริการ squid ไม่ทำงาน — ตรวจสอบไฟล์ตั้งค่าด้วย squid -k parse แล้วดู log ที่ /var/log/squid/cache.log\033[0m"
fi
elif [[ -e /etc/squid3/squid.conf ]]; then
echo -ne "\033[1;33mกำลังรีสตาร์ท SQUID PROXY "; fun_prog 'service squid3 restart'
echo ""
sleep 1
if ! pgrep -x squid3 > /dev/null 2>&1; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m รีสตาร์ท SQUID PROXY ไม่สำเร็จ: บริการ squid3 ไม่ทำงาน — ตรวจสอบไฟล์ตั้งค่าด้วย squid3 -k parse แล้วดู log ที่ /var/log/squid3/cache.log\033[0m"
fi
fi
if [[ -e /etc/stunnel/stunnel.conf ]]; then
echo -ne "\033[1;33mกำลังรีสตาร์ท SSL TUNNEL "; fun_prog 'service stunnel4 restart'
echo ""
sleep 1
if ! pgrep -x stunnel4 > /dev/null 2>&1; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m รีสตาร์ท SSL TUNNEL ไม่สำเร็จ: บริการ stunnel4 ไม่ทำงาน — ตรวจสอบไฟล์ /etc/stunnel/stunnel.conf และใบรับรอง SSL ว่าถูกต้อง\033[0m"
fi
fi
if [[ -e /etc/init.d/dropbear ]]; then
echo -ne "\033[1;33mกำลังรีสตาร์ท DROPBEAR "; fun_prog 'service dropbear restart'
echo ""
sleep 1
if ! pgrep -x dropbear > /dev/null 2>&1; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m รีสตาร์ท DROPBEAR ไม่สำเร็จ: บริการ dropbear ไม่ทำงาน — ตรวจสอบพอร์ตใน /etc/default/dropbear ว่าไม่ชนกับบริการอื่น\033[0m"
fi
fi
if [[ -e /etc/openvpn/server.conf ]]; then
echo -ne "\033[1;33mกำลังรีสตาร์ท OPENVPN "; fun_prog 'service openvpn restart'
echo ""
sleep 1
if ! pgrep -x openvpn > /dev/null 2>&1; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m รีสตาร์ท OPENVPN ไม่สำเร็จ: บริการ openvpn ไม่ทำงาน — ตรวจสอบไฟล์ /etc/openvpn/server.conf แล้วดู log ด้วย journalctl -u openvpn\033[0m"
fi
fi
if netstat -nltp|grep 'apache2' > /dev/null; then
echo -ne "\033[1;33mกำลังรีสตาร์ท APACHE2 "; fun_prog '/etc/init.d/apache2 restart'
echo ""
sleep 1
if ! pgrep -x apache2 > /dev/null 2>&1; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m รีสตาร์ท APACHE2 ไม่สำเร็จ: บริการ apache2 ไม่ทำงาน — ตรวจสอบการตั้งค่าด้วย apache2ctl configtest แล้วดู log ที่ /var/log/apache2/error.log\033[0m"
fi
fi
if ! pgrep -x sshd > /dev/null 2>&1 && ! service ssh status > /dev/null 2>&1; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m รีสตาร์ท OPENSSH ไม่สำเร็จ: บริการ ssh ไม่ทำงาน — ลองรัน service ssh restart ด้วยตนเอง แล้วตรวจสอบ log ที่ /var/log/auth.log\033[0m"
fi
echo -e "\033[1;32mรีสตาร์ทบริการทั้งหมดเสร็จสิ้น!\033[0m"
sleep 1
