#!/bin/bash
tput setaf 7 ; tput setab 4 ; tput bold ; printf '%20s%s\n' "   เปลี่ยนขีดจำกัดการเชื่อมต่อ   " ; tput sgr0
database="/root/usuarios.db"
if [ ! -f "$database" ]; then
	echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m เปิดฐานข้อมูลไม่สำเร็จ: ไม่พบไฟล์ $database — ตรวจสอบว่าติดตั้ง SSHPlus ถูกต้อง หรือสร้างไฟล์ด้วยคำสั่ง touch $database\033[0m\n"
	exit 1
else
	tput setaf 3 ; tput bold ; echo ""; echo "รายชื่อผู้ใช้และจำนวนอุปกรณ์ที่ใช้พร้อมกัน:" ; tput sgr0
	echo ""
	_userT=$(awk -F: '$3>=1000 {print $1}' /etc/passwd | grep -v nobody)
	i=0
	unset _userPass
	while read _user; do
		i=$(expr $i + 1)
		_oP=$i
		[[ $i == [1-9] ]] && i=0$i && oP+=" 0$i"
		if [[ "$(grep -wc "$_user" $database)" != "0" ]]; then
			limit=$(grep -w "$_user" $database |cut -d' ' -f2)
		else
			limit='1'
		fi
		l_user=$(echo -e "\033[1;31m[\033[1;36m$i\033[1;31m] \033[1;37m- \033[1;32m$_user\033[0m")
        lim=$(echo -e "\033[1;33mจำนวนอุปกรณ์\033[1;37m: $limit")
        printf '%-65s%s\n' "$l_user" "$lim"
		_userPass+="\n${_oP}:${_user}"
	done <<< "${_userT}"
	echo ""
	num_user=$(awk -F: '$3>=1000 {print $1}' /etc/passwd | grep -v nobody | wc -l)
	echo -ne "\033[1;32mCHOOSE USER ? \033[1;33m[\033[1;36m1\033[1;31m-\033[1;36m$num_user\033[1;33m]\033[1;37m: " ; read option
	usuario=$(echo -e "${_userPass}" | grep -E "\b$option\b" | cut -d: -f2)
    if [[ -z $option ]]; then
        echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m เปลี่ยนจำนวนอุปกรณ์ไม่สำเร็จ: ไม่ได้เลือกหมายเลขผู้ใช้ — กรุณาพิมพ์หมายเลข 1-$num_user\033[0m\n"
		exit
	elif [[ -z $usuario ]]; then
		echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m เปลี่ยนจำนวนอุปกรณ์ไม่สำเร็จ: หมายเลข \"$option\" ไม่ตรงกับผู้ใช้ในรายการ — กรุณาพิมพ์หมายเลข 1-$num_user\033[0m\n"
		exit 1
	else
		if cat /etc/passwd |grep -w $usuario > /dev/null; then
			echo -ne "\n\033[1;32mSELECT CONNECTION FOR USER? \033[1;33m$usuario\033[1;37m: "; read sshnum
			if [[ -z $sshnum ]]
			then
				echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m จำนวนอุปกรณ์ที่ใช้พร้อมกันไม่ถูกต้อง: ไม่ได้ระบุจำนวน — กรุณาพิมพ์จำนวนอุปกรณ์ เช่น 1\033[0m\n"
				exit 1
			else
				if (echo $sshnum | egrep [^0-9] &> /dev/null)
				then
					echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m จำนวนอุปกรณ์ที่ใช้พร้อมกันไม่ถูกต้อง: ต้องเป็นตัวเลขเท่านั้น — กรุณาพิมพ์เฉพาะตัวเลข เช่น 1\033[0m\n"
					exit 1
				else
					if [[ $sshnum -lt 1 ]]
					then
						echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m จำนวนอุปกรณ์ที่ใช้พร้อมกันไม่ถูกต้อง: ต้องมากกว่าศูนย์ — กรุณาพิมพ์ตัวเลขตั้งแต่ 1 ขึ้นไป\033[0m\n"
						exit 1
					else
						grep -v ^$usuario[[:space:]] /root/usuarios.db > /tmp/a
						sleep 1
						mv /tmp/a /root/usuarios.db || {
							echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m บันทึกฐานข้อมูลไม่สำเร็จ: ไม่สามารถเขียนไฟล์ /root/usuarios.db ได้ — ตรวจสอบสิทธิ์ root และพื้นที่ดิสก์ แล้วลองใหม่อีกครั้ง\033[0m\n"
							exit 1
						}
						echo $usuario $sshnum >> /root/usuarios.db
						tput setaf 7 ; tput setab 4 ; tput bold ; echo "" ; echo "ตั้งจำนวนอุปกรณ์ที่ใช้พร้อมกันใหม่สำหรับ $usuario เป็น $sshnum เครื่อง " ; tput sgr0
						sleep 2
						exit
					fi
				fi
			fi
		else
			echo -e "\n\033[1;31m[ผิดพลาด]\033[1;33m เปลี่ยนจำนวนอุปกรณ์ไม่สำเร็จ: ไม่พบผู้ใช้ชื่อนี้ในระบบ ($usuario) — กรุณาตรวจสอบรายชื่อผู้ใช้แล้วลองใหม่อีกครั้ง\033[0m\n"
			exit 1
		fi
	fi
fi