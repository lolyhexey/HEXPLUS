#!/bin/bash 
sleep 2
clear
echo ""
if ! command -v speedtest-cli > /dev/null 2>&1; then
	echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ทดสอบความเร็วไม่ได้: ไม่พบคำสั่ง speedtest-cli — กรุณาติดตั้งด้วย apt-get install speedtest-cli หรือ pip install speedtest-cli\033[0m"
	echo ""
	exit 1
fi
echo -e "\033[1;33mกำลังทดสอบความเร็ว กรุณารอสักครู่...\033[0m"
echo "--------------------------------------------------------------------"
speedtest-cli --share
echo ""

echo "--------------------------------------------------------------------"