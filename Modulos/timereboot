#!/bin/bash
if [[ $1 == "" ]]
then
clear
echo " ┈╭━━━━━━━━━━━━━━━━━━━━━━╮ "
echo " ┈┣  🕰🕰 ตั้งเวลา Restart vps 🕰🕰 "
echo " ┈╰━┳━━━━━┳━━━━━━━━━━━━━━╯ "
echo " ┈╭━┻━━━━━┻━━━━━━━━━━━━━━╮ "
echo " ┈┣  🕰 1. ทุกวัน เวลา ตีหนึ่ง "
echo " ┈┣━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 2. ทุกๆ 07 วัน. "
echo " ┈┣━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 3. ทุกๆ 01 เดือน. "
echo " ┈┣━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 4. กำหนดค่าเอง "
echo " ┈┣━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 5. ปิดใช้งานรีบูตอัตโนมัติ "
echo " ┈╰━━━━━━━━━━━━━━━━━━━━━━╯"
echo " "
read -p " ┈┣  พิมพ์เลือก : " opcao
else
opcao=$1
fi
case $opcao in
  01 | 1 )
  echo " 00 1 * * * root /sbin/reboot" > /etc/cron.d/reboot
clear
echo " ┈╭━━━━━━━━━━━━━━━━━━━━━━╮ "
echo " ┈┣  🕰 ตั้งเวลา Restart vps 🕰 "
echo " ┈╰━━━━━━━┳━━━━━┳━━━━━━━━╯ "
echo " ┈╭━━━━━━━┻━━━━━┻━━━━━━━━╮ "
echo " ┈┣  🕰 ทุกวันเวลาตีหนึ่งเรียบร้อยแล้ว 🕰 "
echo " ┈╰━━━━━━━━━━━━━━━━━━━━━━╯ "
service cron restart;;
  02 | 2 )
  echo " 0 0 * * 0 root /sbin/reboot" > /etc/cron.d/reboot
clear
echo " ┈╭━━━━━━━━━━━━━━━━━━━━━━╮ "
echo " ┈┣  🕰 ตั้งเวลา Restart vps 🕰 "
echo " ┈╰━━━━━━━┳━━━━━┳━━━━━━━━╯ "
echo " ┈╭━━━━━━━┻━━━━━┻━━━━━━━━╮ "
echo " ┈┣  🕰 ทุกๆ 7 วัน เรียบร้อยแล้ว 🕰 "
echo " ┈╰━━━━━━━━━━━━━━━━━━━━━━╯ "
service cron restart;;
  03 | 3 )
  echo " 0 0 1 * * root /sbin/reboot" > /etc/cron.d/reboot
clear
echo " ┈╭━━━━━━━━━━━━━━━━━━━━━━╮ "
echo " ┈┣  🕰 ตั้งเวลา Restart vps 🕰 "
echo " ┈╰━━━━━━━┳━━━━━┳━━━━━━━━╯ "
echo " ┈╭━━━━━━━┻━━━━━┻━━━━━━━━╮ "
echo " ┈┣  🕰 ทุก 1 เดือน เรียบร้อยแล้ว 🕰 "
echo " ┈╰━━━━━━━━━━━━━━━━━━━━━━╯ "
service cron restart;;
  04 | 4 )
clear
  echo " "
  echo " ┈╭━━━━━━━━━━━━━━━━━━━━━━╮ "
echo " ┈┣  🕰🕰 ตัวอย่างการตั้งค่า 🕰🕰 "
echo " ┈╰━━━━━━━┳━━━━━┳━━━━━━━━╯ "
echo " ┈╭━━━━━━━┻━━━━━┻━━━━━━━━╮ "
echo " ┈┣  🕰 0 * * * *   คือ 1ชม "
echo " ┈┣━━━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 0 */6 * * * คือ 6ชม "
echo " ┈┣━━━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 30 3 * * *  คือ ทุกวัน เวลา ตีสามครึ่ง "
echo " ┈┣━━━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 0 0 * * 0   คือ 7วัน "
echo " ┈┣━━━━━━━━━━━━━━━━┫"
echo " ┈┣  🕰 0 0 1 * *   คือ 1เดือน "
echo " ┈╰━━━━━━━━━━━━━━━━━━━━━━╯"
  
read -p " เวลา ( 0 0 * * 0 ) : " Set
if [[ -z "$Set" ]] || ! [[ "$Set" =~ ^[0-9*/,-]+[[:space:]]+[0-9*/,-]+[[:space:]]+[0-9*/,-]+[[:space:]]+[0-9*/,-]+[[:space:]]+[0-9*/,-]+$ ]]; then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ตั้งเวลารีบูตไม่สำเร็จ: รูปแบบเวลา cron ไม่ถูกต้อง — ต้องมี 5 ช่อง เช่น 0 0 * * 0\033[0m"
else
min_f=$(echo "$Set" | awk '{print $1}')
hr_f=$(echo "$Set" | awk '{print $2}')
if [[ "$min_f" =~ ^[0-9]+$ ]] && (( 10#$min_f > 59 )); then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ตั้งเวลารีบูตไม่สำเร็จ: นาทีต้องเป็นตัวเลข 0-59 — กรุณาแก้ไขช่องแรก (นาที) ให้อยู่ระหว่าง 0-59\033[0m"
elif [[ "$hr_f" =~ ^[0-9]+$ ]] && (( 10#$hr_f > 23 )); then
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ตั้งเวลารีบูตไม่สำเร็จ: ชั่วโมงต้องเป็นตัวเลข 0-23 — กรุณาแก้ไขช่องที่สอง (ชั่วโมง) ให้อยู่ระหว่าง 0-23\033[0m"
else
echo "$Set root /sbin/reboot" > /etc/cron.d/reboot
service cron restart
fi
fi
echo -e " ";;
 05 | 5 )
echo " " > /etc/cron.d/reboot
clear
echo " ┈╭━━━━━━━━━━━━━━━━━━━━━━╮ "
echo " ┈┣  🕰 ปิด Restart vps เรียบร้อยแล้ว 🕰 "
echo " ┈╰━━━━━━━━━━━━━━━━━━━━━━╯ "
service cron restart
echo -e " ";;
  * )
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ตัวเลือกไม่ถูกต้อง: '$opcao' ไม่อยู่ในเมนู — กรุณาเลือก 1-5\033[0m";;
esac

