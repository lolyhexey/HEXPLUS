function limit1 () {
   clear
   echo -e "\n\033[1;32mกำลังเริ่ม LIMITER... \033[0m"
   echo ""
   if ! command -v limiter > /dev/null 2>&1; then
      echo -e "\033[1;31m[ผิดพลาด]\033[1;33m เริ่ม LIMITER ไม่ได้: ไม่พบคำสั่ง limiter — ติดตั้งสคริปต์ใหม่หรือตรวจสอบว่าไฟล์ limiter อยู่ใน PATH\033[0m"
      sleep 3
      menu
      return
   fi
   [[ ! -e /etc/autostart ]] && touch /etc/autostart
   fun_bar 'screen -dmS limiter limiter' 'sleep 3'
   [[ $(grep -wc "limiter" /etc/autostart) = '0' ]] && {
       echo -e "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >> /etc/autostart
   } || {
       sed -i '/limiter/d' /etc/autostart
	   echo -e "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >> /etc/autostart
   }
   echo -e "\n\033[1;32m  LIMITER เปิดใช้งานอยู่ !\033[0m"
   sleep 3
   menu
}
function limit2 () {
   clear
   echo -e "\033[1;32mกำลังหยุด LIMITER... \033[0m"
