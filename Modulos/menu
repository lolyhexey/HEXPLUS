function autoexec () {
   if grep "menu;" /etc/profile > /dev/null; then
      clear
      echo -e "\033[1;32mกำลังปิดการเปิดเมนูอัตโนมัติ\033[0m"
      offautmenu () {
         sed -i '/menu;/d' /etc/profile
      }
      echo ""
      fun_bar 'offautmenu'
      echo ""
      echo -e "\033[1;31mการเปิดเมนูอัตโนมัติปิดอยู่!\033[0m"
      sleep 1.5s
      menu2
   else
      clear
      echo -e "\033[1;32mกำลังเปิดการเปิดเมนูอัตโนมัติ\033[0m"
      autmenu () {
         grep -v "^menu;" /etc/profile > /tmp/tmpass && mv /tmp/tmpass /etc/profile
         echo "menu;" >> /etc/profile
      }
      echo ""
      fun_bar 'autmenu'
      echo ""
      echo -e "\033[1;32mการเปิดเมนูอัตโนมัติเปิดใช้งานอยู่!\033[0m"
      sleep 1.5s
