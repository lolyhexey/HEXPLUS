#!/bin/bash
clear
echo -e "\E[44;1;37m               ข้อมูลเซิร์ฟเวอร์ VPS                 \E[0m"
echo ""
if [ -f /etc/lsb-release ]
then
echo -e "\033[1;31m• \033[1;32mระบบปฏิบัติการ\033[1;31m •\033[0m"
echo ""
name=$(cat /etc/lsb-release |grep DESCRIPTION |awk -F = {'print $2'})
codename=$(cat /etc/lsb-release |grep CODENAME |awk -F = {'print $2'})
echo -e "\033[1;33mชื่อ: \033[1;37m$name"
echo -e "\033[1;33mชื่อรหัส (CodeName): \033[1;37m$codename"
echo -e "\033[1;33mเคอร์เนล: \033[1;37m$(uname -s)"
echo -e "\033[1;33mรุ่นเคอร์เนล: \033[1;37m$(uname -r)"
if [ -f /etc/os-release ]
then
devlike=$(cat /etc/os-release |grep LIKE |awk -F = {'print $2'})
echo -e "\033[1;33mพัฒนาต่อจาก OS: \033[1;37m$devlike"
echo ""
fi
elif [ -f /etc/issue.net ]
then
system=$(cat /etc/issue.net)
echo -e "\033[1;31m• \033[1;32mระบบปฏิบัติการ\033[1;31m •\033[0m"
echo ""
echo -e "\033[1;33mชื่อ: \033[1;37m$system"
echo ""
else
echo -e "\033[1;31m• \033[1;32mระบบปฏิบัติการ\033[1;31m •\033[0m"
echo ""
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m อ่านข้อมูลระบบปฏิบัติการไม่ได้: ไม่พบไฟล์ /etc/lsb-release หรือ /etc/issue.net — ระบบนี้อาจไม่รองรับ\033[0m"
echo ""
fi

if [ -f /proc/cpuinfo ]
then
uso=$(top -bn1 | awk '/Cpu/ { cpu = "" 100 - $8 "%" }; END { print cpu }')
echo -e "\033[1;31m• \033[1;32mหน่วยประมวลผล (CPU)\033[1;31m •\033[0m"
echo ""
modelo=$(cat /proc/cpuinfo |grep "model name" |uniq |awk -F : {'print $2'})
cpucores=$(grep -c cpu[0-9] /proc/stat)
cache=$(cat /proc/cpuinfo |grep "cache size" |uniq |awk -F : {'print $2'})
echo -e "\033[1;33mรุ่น:\033[1;37m$modelo"
echo -e "\033[1;33mจำนวนคอร์:\033[1;37m $cpucores"
echo -e "\033[1;33mหน่วยความจำแคช:\033[1;37m$cache"
echo -e "\033[1;33mสถาปัตยกรรม: \033[1;37m$(uname -p)"
echo -e "\033[1;33mการใช้งาน: \033[37m$uso"
echo ""
else
echo -e "\033[1;32mหน่วยประมวลผล (CPU)\033[0m"
echo ""
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m อ่านข้อมูล CPU ไม่ได้: ไม่พบไฟล์ /proc/cpuinfo — ระบบนี้อาจไม่รองรับการอ่านข้อมูล CPU\033[0m"
fi

if free 1>/dev/null 2>/dev/null
then
ram1=$(free -h | grep -i mem | awk {'print $2'})
ram2=$(free -h | grep -i mem | awk {'print $4'})
ram3=$(free -h | grep -i mem | awk {'print $3'})
usoram=$(free -m | awk 'NR==2{printf "%.2f%%\t\t", $3*100/$2 }')

echo -e "\033[1;31m• \033[1;32mหน่วยความจำ RAM\033[1;31m •\033[0m"
echo ""
echo -e "\033[1;33mทั้งหมด: \033[1;37m$ram1"
echo -e "\033[1;33mใช้งานอยู่: \033[1;37m$ram3"
echo -e "\033[1;33mว่าง: \033[1;37m$ram2"
echo -e "\033[1;33mการใช้งาน: \033[37m$usoram"
echo ""
else
echo -e "\033[1;32mหน่วยความจำ RAM\033[0m"
echo ""
echo -e "\033[1;31m[ผิดพลาด]\033[1;33m อ่านข้อมูลหน่วยความจำไม่ได้: ไม่พบคำสั่ง free — กรุณาติดตั้งแพ็กเกจ procps (apt-get install procps)\033[0m"
fi
[[ ! -e /bin/versao ]] && rm -rf /etc/SSHPlus
echo -e "\033[1;31m• \033[1;32mบริการที่กำลังทำงาน\033[1;31m •\033[0m"
echo ""
if ! command -v lsof > /dev/null 2>&1; then
    echo -e "\033[1;31m[ผิดพลาด]\033[1;33m แสดงบริการที่กำลังทำงานไม่ได้: ไม่พบคำสั่ง lsof — กรุณาติดตั้งด้วย apt-get install lsof\033[0m"
else
PT=$(lsof -V -i tcp -P -n | grep -v "ESTABLISHED" |grep -v "COMMAND" | grep "LISTEN")
for porta in `echo -e "$PT" | cut -d: -f2 | cut -d' ' -f1 | uniq`; do
    svcs=$(echo -e "$PT" | grep -w "$porta" | awk '{print $1}' | uniq)
    echo -e "\033[1;33mบริการ \033[1;37m$svcs \033[1;33mพอร์ต \033[1;37m$porta"
done
fi