#!/bin/bash
if [ -d "/etc/squid/" ]; then
    payload="/etc/squid/payload.txt"
elif [ -d "/etc/squid3/" ]; then
	payload="/etc/squid3/payload.txt"
fi
tput setaf 7 ; tput setab 4 ; tput bold ; printf '%35s%s%-10s\n' "ลบ Host ออกจาก Squid Proxy" ; tput sgr0
if [ ! -f "$payload" ]
then
	echo "" ; echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ลบ Host ไม่สำเร็จ: ไม่พบไฟล์ $payload — Squid Proxy อาจยังไม่ได้ติดตั้ง กรุณาติดตั้ง Squid ก่อน\033[0m" ; tput sgr0
	exit 1
else
	tput setaf 2 ; tput bold ; echo ""; echo "โดเมนปัจจุบันในไฟล์ $payload:" ; tput sgr0
	tput setaf 3 ; tput bold ; echo "" ; cat $payload ; echo "" ; tput sgr0
	read -p "พิมพ์โดเมนที่ต้องการลบออกจากรายการ: " host
	if [[ -z $host ]]
		then
			echo "" ; echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ลบโดเมนไม่สำเร็จ: ไม่ได้กรอกโดเมน — กรุณาพิมพ์โดเมนให้ตรงกับรายการด้านบน\033[0m" ; echo "" ; tput sgr0
			exit 1
		else
		if [[ `grep -c "^$host" $payload` -ne 1 ]]
		then
			echo "" ; echo -e "\033[1;31m[ผิดพลาด]\033[1;33m ลบโดเมนไม่สำเร็จ: ไม่พบโดเมน $host ในไฟล์ $payload — ตรวจสอบรายการด้านบนแล้วพิมพ์ให้ตรง\033[0m" ; echo "" ; tput sgr0
			exit 1
		else
			grep -v "^$host" $payload > /tmp/a && mv /tmp/a $payload
			tput setaf 7 ; tput setab 1 ; tput bold ; echo "" ; echo "อัปเดตไฟล์ $payload แล้ว ลบโดเมนเรียบร้อย:" ; tput sgr0
			tput setaf 3 ; tput bold ; echo "" ; cat $payload ; echo "" ; tput sgr0
			if [ ! -f "/etc/init.d/squid3" ]
			then
				service squid3 reload
			elif [ ! -f "/etc/init.d/squid" ]
			then
				service squid reload
			fi
			tput setaf 7 ; tput setab 1 ; tput bold ; echo "" ; echo "รีโหลด Squid Proxy เรียบร้อยแล้ว!" ; echo "" ; tput sgr0
			exit 1
		fi
	fi
fi