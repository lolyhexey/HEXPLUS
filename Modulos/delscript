#!/bin/bash
[[ -f /etc/SSHPlus/lib.sh ]] && source /etc/SSHPlus/lib.sh || { run() { shift; "$@" >/dev/null 2>&1; }; run_soft() { shift; "$@" >/dev/null 2>&1; }; }
SSHPLUS_CTX="delscript"

clear
echo -e "\033[1;32mต้องการถอนการติดตั้ง SSHPLUS MANAGER หรือไม่\033[1;33m"
read -p "ต้องการลบหรือไม่? [s/n] " resp
if [[ "$resp" = s || "$resp" = S || "$resp" = y || "$resp" = Y ]];then
    log_info "uninstall started by user"
    echo -e "\033[1;33mกำลังหยุดบริการและ screen sessions...\033[0m"
    # Stop screen sessions
    screen -ls 2>/dev/null | grep -E 'limiter|onlineapp|badudp' | awk '{print $1}' | while read s; do
        run_soft "screen quit $s" screen -X -S "$s" quit
    done
    run_soft "screen wipe" screen -wipe

    # --- BadVPN ---
    run_soft "kill badvpn-udpgw" pkill -9 badvpn-udpgw
    run_soft "rm badvpn-udpgw bin" rm -f /usr/local/bin/badvpn-udpgw
    run_soft "rm badvpn shims" rm -f /bin/badudp /bin/badvpn

    run_soft "systemctl daemon-reload" systemctl daemon-reload

    # --- Original packages and binaries ---
    run "purge screen" apt-get purge screen -y
    run "purge nmap" apt-get purge nmap -y
    run "purge figlet" apt-get purge figlet -y
    run "purge squid" apt-get purge squid -y
    run "purge squid3" apt-get purge squid3 -y
    run "purge dropbear" apt-get purge dropbear -y
    run "purge apache2" apt-get purge apache2 -y
    run "apt autoremove" apt-get autoremove -y

    run_soft "rm /bin shims" rm /bin/criarusuario /bin/expcleaner /bin/sshlimiter /bin/addhost /bin/listar /bin/sshmonitor /bin/ajuda /bin/menu /bin/OpenVPN /bin/userbackup /bin/tcpspeed /bin/badvpn /bin/otimizar /bin/speedtest /bin/trafego /bin/banner /bin/limit /bin/limite /bin/senharoot /bin/reiniciarservicos /bin/reiniciarsistema /bin/attscript /bin/criarteste /bin/socks /bin/DropBear /bin/alterarlimite /bin/alterarsenha /bin/remover /bin/detalhes /bin/mudardata /bin/infousers /bin/droplimiter /bin/conexao /bin/onlineapp /bin/versao
    run_soft "rm /etc/SSHPlus" rm -rf /etc/SSHPlus
    log_info "uninstall finished"
    clear
    echo -e "\033[1;36mขอบคุณที่ใช้งาน SSHPLUS MANAGER\033[1;33m"
    sleep 2
    cat /dev/null > ~/.bash_history && history -c && exit 0
else
    echo -e "\033[1;32mตกลง กำลังกลับสู่เมนู\033[1;33m"
    sleep 3
    menu
fi
