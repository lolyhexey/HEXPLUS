#!/bin/bash
clear
echo -e "\033[1;32mต้องการถอนการติดตั้ง SSHPLUS MANAGER หรือไม่\033[1;33m"
read -p "ต้องการลบหรือไม่? [s/n] " resp
if [[ "$resp" = s || "$resp" = S || "$resp" = y || "$resp" = Y ]];then
    echo -e "\033[1;33mกำลังหยุดบริการและ screen sessions...\033[0m"
    # Stop screen sessions
    screen -ls 2>/dev/null | grep -E 'limiter|onlineapp|bot_plus|bot_teste|badudp|slowdns' | awk '{print $1}' | while read s; do
        screen -X -S "$s" quit > /dev/null 2>&1
    done
    screen -wipe > /dev/null 2>&1

    # --- Trojan-Go (docker container + config) ---
    docker stop Trojan-Go > /dev/null 2>&1
    docker rm Trojan-Go > /dev/null 2>&1
    docker rmi teddysun/trojan-go > /dev/null 2>&1
    rm -rf /etc/trojan-go > /dev/null 2>&1
    rm -f /bin/trojan-go > /dev/null 2>&1

    # --- V2Ray / Xray ---
    systemctl stop v2ray > /dev/null 2>&1
    systemctl disable v2ray > /dev/null 2>&1
    systemctl stop xray > /dev/null 2>&1
    systemctl disable xray > /dev/null 2>&1
    rm -rf /usr/bin/v2ray /usr/bin/xray > /dev/null 2>&1
    rm -rf /etc/v2ray /etc/xray > /dev/null 2>&1
    rm -rf /var/log/v2ray /var/log/xray > /dev/null 2>&1
    rm -f /etc/systemd/system/v2ray.service /lib/systemd/system/v2ray.service > /dev/null 2>&1
    rm -f /etc/systemd/system/xray.service /lib/systemd/system/xray.service > /dev/null 2>&1
    rm -f /bin/v2raymanager > /dev/null 2>&1

    # --- BadVPN ---
    pkill -9 badvpn-udpgw > /dev/null 2>&1
    rm -f /usr/local/bin/badvpn-udpgw > /dev/null 2>&1
    rm -f /bin/badudp /bin/badvpn > /dev/null 2>&1

    # --- SlowDNS ---
    systemctl stop slowdns > /dev/null 2>&1
    systemctl disable slowdns > /dev/null 2>&1
    pkill -9 dns-server > /dev/null 2>&1
    rm -rf /etc/slowdns > /dev/null 2>&1
    rm -f /bin/slowdns > /dev/null 2>&1
    rm -f /etc/systemd/system/slowdns.service > /dev/null 2>&1

    # --- Nginx + PHP ---
    systemctl stop nginx php7.4-fpm > /dev/null 2>&1
    apt-get purge nginx nginx-common nginx-core -y > /dev/null 2>&1
    apt-get purge 'php7.4*' -y > /dev/null 2>&1
    rm -rf /etc/nginx > /dev/null 2>&1
    rm -rf /home/website > /dev/null 2>&1
    rm -rf /var/www/html/server > /dev/null 2>&1

    systemctl daemon-reload > /dev/null 2>&1

    # --- Original packages and binaries ---
    apt-get purge screen -y > /dev/null 2>&1
    apt-get purge nmap -y > /dev/null 2>&1
    apt-get purge figlet -y > /dev/null 2>&1
    apt-get purge squid -y > /dev/null 2>&1
    apt-get purge squid3 -y > /dev/null 2>&1
    apt-get purge dropbear -y > /dev/null 2>&1
    apt-get purge apache2 -y > /dev/null 2>&1
    apt-get autoremove -y > /dev/null 2>&1

    rm /bin/criarusuario /bin/expcleaner /bin/sshlimiter /bin/addhost /bin/listar /bin/sshmonitor /bin/ajuda /bin/menu /bin/OpenVPN /bin/userbackup /bin/tcpspeed /bin/badvpn /bin/otimizar /bin/speedtest /bin/trafego /bin/banner /bin/limit /bin/limite /bin/senharoot /bin/reiniciarservicos /bin/reiniciarsistema /bin/attscript /bin/criarteste /bin/socks  /bin/DropBear /bin/alterarlimite /bin/alterarsenha /bin/remover /bin/detalhes /bin/mudardata /bin/botssh /bin/infousers /bin/droplimiter /bin/conexao /bin/onlineapp /bin/botteste /bin/trojan-go /bin/v2raymanager /bin/versao > /dev/null 2>&1
    rm -rf /etc/SSHPlus > /dev/null 2>&1
    clear
    echo -e "\033[1;36mขอบคุณที่ใช้งาน SSHPLUS MANAGER\033[1;33m"
    sleep 2
    cat /dev/null > ~/.bash_history && history -c && exit 0
else
    echo -e "\033[1;32mตกลง กำลังกลับสู่เมนู\033[1;33m"
    sleep 3
    menu
fi
