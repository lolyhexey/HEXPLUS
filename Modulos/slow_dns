#!/bin/bash
clear
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
CORTITLE='\033[1;41m'
DIR='/etc/SSHPlus/dns'
SCOLOR='\033[0m'

configdns() {
    interface=$(ip a | awk '/state UP/{print $2}' | cut -d: -f1)
    iptables -F >/dev/null 2>&1
    iptables -I INPUT -p udp --dport 5300 -j ACCEPT
    iptables -t nat -I PREROUTING -i $interface -p udp --dport 53 -j REDIRECT --to-ports 5300
    ip6tables -I INPUT -p udp --dport 5300 -j ACCEPT
    ip6tables -t nat -I PREROUTING -i $interface -p udp --dport 53 -j REDIRECT --to-ports 5300
}

echo -e "${CORTITLE}           SSHPLUS SLOWDNS (Beta)            ${SCOLOR}"
installslowdns() {
    echo -e "\n${YELLOW}โปรดทราบว่าวิธีนี้ยังอยู่ใน\nช่วงทดสอบ (BETA) นอกจากจะช้าแล้ว\nอาจทำงานได้ไม่สมบูรณ์ ! ${SCOLOR}\n"
    echo -ne "${GREEN}ต้องการติดตั้งต่อหรือไม่ ? ${YELLOW}[s/n]:${SCOLOR} "
    read resp
    [[ "$resp" != @(s|sim|S|SIM) ]] && {
        echo -e "\n${RED}กำลังกลับสู่เมนู...${SCOLOR}"
        sleep 2
        conexao
    }
    mkdir /etc/SSHPlus/dns >/dev/null 2>&1
    wget -P $DIR https://github.com/rodrigo12xd/SSHPLUS/raw/master/Install/dns-server >/dev/null 2>&1
    [[ ! -e $DIR/dns-server ]] && {
        echo -e "\n${RED}[ผิดพลาด]${YELLOW} ติดตั้ง SlowDNS ไม่สำเร็จ: ดาวน์โหลดไม่สำเร็จ — เช็คอินเทอร์เน็ตของเซิร์ฟเวอร์แล้วลองใหม่${SCOLOR}"
        rm -rf $DIR >/dev/null 2>&1
        sleep 3
        conexao
    }
    chmod 777 $DIR/dns-server >/dev/null 2>&1
    $DIR/dns-server -gen-key -privkey-file $DIR/server.key -pubkey-file $DIR/server.pub >/dev/null 2>&1
    configdns >/dev/null 2>&1
    cat /dev/null >~/.bash_history && history -c
}
initslow() {
    [[ $(ss -lu | grep -wc '5300') != '0' ]] && {
        echo -e "\n${RED}[${CYAN}1${RED}] ${YELLOW}หยุด SLOWDNS${SCOLOR}"
        echo -e "${RED}[${CYAN}2${RED}] ${YELLOW}ลบ SLOWDNS${SCOLOR}"
        echo -e "${RED}[${CYAN}3${RED}] ${YELLOW}แสดงข้อมูล${SCOLOR}"
        echo -e "${RED}[${CYAN}0${RED}] ${YELLOW}กลับ${SCOLOR}"
        echo -ne "\n${GREEN}เลือกตัวเลือก${SCOLOR}: "
        read op
        if [[ "$op" == '1' ]]; then
            screen -r -S "slow_dns" -X quit >/dev/null 2>&1
            screen -wipe >/dev/null 2>&1
            sed -i '/5300/d' /etc/autostart >/dev/null 2>&1
            sed -i '/slow_dns/d' /etc/SSHPlus/dns/autodns >/dev/null 2>&1
            echo -e "\n${RED}SLOWDNS ปิดอยู่ !${SCOLOR}"
            sleep 2
            conexao
        elif [[ "$op" == '2' ]]; then
            screen -r -S "slow_dns" -X quit >/dev/null 2>&1
            screen -wipe >/dev/null 2>&1
            sed -i '/5300/d' /etc/autostart >/dev/null 2>&1
            rm -rf /etc/SSHPlus/dns >/dev/null 2>&1
            echo -e "\n${RED}ลบ SLOWDNS แล้ว !${SCOLOR}"
            sleep 2
            conexao
        elif [[ "$op" == '3' ]]; then
            [[ -e $DIR/server.pub ]] && keypub=$(cat $DIR/server.pub) || keypub='Null'
            [[ -e $DIR/autodns ]] && nameserver=$(grep -w 'server.key' /etc/SSHPlus/dns/autodns | awk -F' ' '{print $9}') || nameserver='Null'
            tmx='curl -sO https://raw.githubusercontent.com/rodrigo12xd/SSHPLUS/master/Install/slowdns && chmod +x slowdns && ./slowdns'
            clear
            echo -e "${CORTITLE}           SSHPLUS SLOWDNS (Beta)            ${SCOLOR}"
            echo -e "\n${YELLOW}NAMESERVER(NS)${SCOLOR}: $nameserver"
            echo -e "${YELLOW}คีย์สาธารณะ${SCOLOR}: $keypub"
            echo -e "\n${GREEN}คำสั่ง TERMUX${SCOLOR}: ${tmx} ${nameserver} ${keypub}"
            echo -ne "\n${RED}กด ENTER${YELLOW} เพื่อกลับ${GREEN}เมนู!${SCOLOR}"
            read
            conexao
        elif [[ "$op" == '0' ]]; then
            sleep 1
            conexao
        else
            echo -e "\n${RED}[ผิดพลาด]${YELLOW} ตัวเลือกไม่ถูกต้อง: ไม่มีตัวเลือกนี้ — กรุณาเลือก 0-3${SCOLOR}"
            sleep 1.5
            conexao
        fi
    } || {
        clear
        echo -e "${CORTITLE}           SSHPLUS SLOWDNS (Beta)            ${SCOLOR}"
        echo -ne "\n${GREEN}กรอกโดเมน NS${SCOLOR}: "
        read ns
        [[ -z "$ns" ]] && {
            echo -e "\n${RED}[ผิดพลาด]${YELLOW} โดเมนไม่ถูกต้อง: ยังไม่ได้กรอกข้อมูล — กรุณากรอกโดเมน NS\033[0m"
            sleep 1.5
            initslow
        }
        echo -e "\n${RED}[${CYAN}1${RED}] ${YELLOW}SLOWDNS SSH${SCOLOR}"
        echo -e "${RED}[${CYAN}2${RED}] ${YELLOW}SLOWDNS SSL${SCOLOR}"
        echo -e "${RED}[${CYAN}3${RED}] ${YELLOW}SLOWDNS SSLH${SCOLOR}"
        echo -e "${RED}[${CYAN}4${RED}] ${YELLOW}SLOWDNS OPENVPN${SCOLOR}"
        echo -e "${RED}[${CYAN}0${RED}] ${YELLOW}กลับ${SCOLOR}"
        echo -ne "\n${GREEN}เลือกตัวเลือก${SCOLOR}: "
        read opcc
        if [[ "$opcc" == '1' ]]; then
            ptdns='22'
        elif [[ "$opcc" == '2' ]]; then
            ptdns=$(netstat -nplt | grep 'stunnel' | awk {'print $4'} | cut -d: -f2)
            [[ $ptdns == '' ]] && {
                echo -e "\n${RED}[ผิดพลาด]${YELLOW} ใช้งาน SLOWDNS SSL ไม่ได้: ยังไม่ได้ติดตั้ง SSL TUNNEL — กรุณาติดตั้ง SSL TUNNEL ก่อน${SCOLOR}"
                sleep 1.5
                initslow
            }
        elif [[ "$opcc" == '3' ]]; then
            ptdns=$(netstat -nplt | grep 'sslh' | awk {'print $4'} | cut -d: -f2)
            [[ $ptdns == '' ]] && {
                echo -e "\n${RED}[ผิดพลาด]${YELLOW} ใช้งาน SLOWDNS SSLH ไม่ได้: ยังไม่ได้ติดตั้ง SSLH — กรุณาติดตั้ง SSLH ก่อน${SCOLOR}"
                sleep 1.5
                initslow
            }
        elif [[ "$opcc" == '4' ]]; then
            [[ ! -e /etc/openvpn/server.conf ]] && {
                echo -e "\n${RED}[ผิดพลาด]${YELLOW} ใช้งาน SLOWDNS OPENVPN ไม่ได้: ยังไม่ได้ติดตั้ง OPENVPN — กรุณาติดตั้ง OPENVPN ก่อน${SCOLOR}"
                sleep 1.5
                initslow
            } || {
                ptdns=$(sed -n 1p /etc/openvpn/server.conf| cut -d' ' -f2)
            }
        elif [[ "$opcc" == '0' ]]; then
            sleep 1.5
            conexao
        else
            echo -e "\n${RED}[ผิดพลาด]${YELLOW} ตัวเลือกไม่ถูกต้อง: ไม่มีตัวเลือกนี้ — กรุณาเลือก 0-4${SCOLOR}"
            sleep 1.5
            initslow
        fi
        screen -dmS slow_dns $DIR/dns-server -udp :5300 -privkey-file $DIR/server.key ${ns} 0.0.0.0:${ptdns} >/dev/null 2>&1
        keypub=$(cat $DIR/server.pub)
        cd $HOME
        echo -e "\n${YELLOW}กำลังเปิดใช้งาน SLOWDNS...${SCOLOR}"
        sleep 2
        [[ $(ss -lu | grep -wc '5300') == '0' ]] && {
            echo -e "\n${RED}[ผิดพลาด]${YELLOW} เปิดใช้งาน SLOWDNS ไม่สำเร็จ: บริการ dns-server ไม่ได้เริ่มทำงานบนพอร์ต 5300 — เช็คว่าพอร์ต 5300 ไม่ถูกใช้งานอยู่แล้วลองใหม่${SCOLOR}"
            sleep 3
            conexao
        }
        [[ ! -e /etc/iptables/rules.v4 ]] && {
            configdns > /dev/null 2>&1
            DEBIAN_FRONTEND=noninteractive apt install -y iptables-persistent >/dev/null 2>&1
        } || {
            sleep 2
            configdns > /dev/null 2>&1
            iptables-save > /etc/iptables/rules.v4
        }
        echo "screen -dmS slow_dns $DIR/dns-server -udp :5300 -privkey-file $DIR/server.key ${ns} 0.0.0.0:${ptdns}" >/etc/SSHPlus/dns/autodns
        chmod 777 /etc/SSHPlus/dns/autodns >/dev/null 2>&1
        echo "ss -lu|grep -w '5300' || /etc/SSHPlus/dns/autodns" >>/etc/autostart
        tmx='curl -sO https://raw.githubusercontent.com/rodrigo12xd/SSHPLUS/master/Install/slowdns && chmod +x slowdns && ./slowdns'
        echo -e "\n${GREEN}SLOWDNS เปิดใช้งานอยู่ !${SCOLOR}"
        echo -e "\n${YELLOW}คำสั่ง TERMUX${SCOLOR}: ${tmx} ${ns} ${keypub}"
        echo -ne "\n${RED}กด ENTER${YELLOW} เพื่อกลับ${GREEN}เมนู!${SCOLOR}"
        read
        conexao
    }
}
[[ -d $DIR ]] && {
    initslow
} || {
    installslowdns
    sleep 0.5
    initslow
}
